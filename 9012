T = int(input())

for _ in range(T):
    s = input()
    stack = []
    
    for x in s:
        if x == '(':
            stack.append(x)
        else: 
            if stack:
                stack.pop()
            else:
                print("NO")
                break
    else:
        if not stack:
            print("YES")
        else:
            print("NO")
