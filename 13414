import sys

K, L = map(int, sys.stdin.readline().split())

arr = [sys.stdin.readline().strip() for _ in range(L)]

seen = set()
result = []

for i in range(L-1, -1, -1):
    if arr[i] not in seen:
        seen.add(arr[i])
        result.append(arr[i])

result.reverse()

for i in range(min(K, len(result))):
    print(result[i])
